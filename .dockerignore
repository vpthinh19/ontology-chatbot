# Keep build context small + reproducible. Anything copied here ends up on
# the Docker daemon even if the Dockerfile never references it.

.git
.github
.gitignore
.gitattributes

# Local venv + caches
.venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache
.tox
.coverage
htmlcov

# Test + training artifacts (model is pulled from HF Hub at runtime)
tests/
artifacts/
logs/
checkpoints/

# Local dev clutter
.idea
.vscode
.DS_Store
*.swp
*.swo

# Build output
dist/
build/
*.egg-info
*.egg

# Docs not needed in runtime image (README is COPY'd explicitly by Dockerfile)
docs/

# This file itself
Dockerfile
.dockerignore
