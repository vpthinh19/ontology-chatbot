@startuml ontchatbot-data-flow

' Vertical waterfall DFD: user query travels top→bottom through the
' Chatbot Interface (the FastAPI + WebUI gateway) and the four core
' pipeline modules — Preprocessor, NerModel, Ontology, Renderer — each
' shown as a dashed-border box to mark them as the engine. Solid boxes
' hold the I/O gateway, the user, and the ontology data store. Edge
' labels carry sample-shaped data (not full JSON) so a reader can see
' how the message changes as it crosses each module boundary.

title NTU Academic Chatbot — Data Flow

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontSize 12
skinparam ArrowColor #111111
skinparam ArrowFontColor #111111
skinparam ArrowFontSize 11

skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor     #111111
    FontColor       #111111
}

skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor     #111111
    FontColor       #111111
    RoundCorner     4
}

' The four core pipeline modules — dashed border + bold title to call
' them out as the engine, distinct from the I/O gateway and data store.
skinparam rectangle<<module>> {
    BorderStyle     dashed
    BorderThickness 1.5
    FontStyle       bold
    RoundCorner     6
}

skinparam database {
    BackgroundColor #FFFFFF
    BorderColor     #111111
    FontColor       #111111
}

' === User → Interface (top entry) ===
actor "User" as USER_IN

rectangle "Chatbot Interface\n(FastAPI + WebUI)" as CI_IN

' === 4 core modules of the pipeline ===
rectangle "Preprocessor" as PRE <<module>>

rectangle "NerModel" as NER <<module>> {
    rectangle "PhoBERT\n(Tokenizer + Model)" as NER_FWD
    rectangle "BIO Decoder" as NER_DEC
    NER_FWD -down-> NER_DEC : [B-QTHV, I-QTHV, O, O]
}

rectangle "Ontology" as ONTO <<module>>

rectangle "Renderer" as REND <<module>>

' === Data store ===
database "Academic\nOntology" as DB

' === Renderer → Interface → User (bottom exit) ===
rectangle "Chatbot Interface\n(FastAPI + WebUI)" as CI_OUT

actor "User" as USER_OUT

' === Waterfall edges with sample-shape labels ===
USER_IN -down-> CI_IN   : "đóng học phí?"
CI_IN   -down-> PRE     : "đóng học phí?"
PRE     -down-> NER_FWD : ["đóng_học_phí", "thì", "sao"]
NER_DEC -down-> ONTO    : [("đóng học phí", "QuyTrinhHocVu")]
ONTO    -right-> DB
DB      -left->  ONTO
ONTO    -down-> REND    : {label, "Mô tả...", ...}
REND    -down-> CI_OUT  : "Quy trình đóng học phí..."
CI_OUT  -down-> USER_OUT

@enduml
