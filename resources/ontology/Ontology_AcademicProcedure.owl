<owl:NamedIndividual rdf:about="#QuyTrinhBaoLuu">
  <rdf:type rdf:resource="#QuyTrinhHocVu"/>
  <duocXuLyBoi rdf:resource="#PhongCTSV"/>
  <yeuCauDieuKien rdf:resource="#DieuKienBaoLuuCaNhan"/>
  <yeuCauDieuKien rdf:resource="#DieuKienBaoLuuQuocTe"/>
  <yeuCauDieuKien rdf:resource="#DieuKienBaoLuuVuTrang"/>
  <yeuCauDieuKien rdf:resource="#DieuKienBaoLuuYTe"/>
  <canTaiLieu rdf:resource="#DonXinBaoLuu"/>
  <canTaiLieu rdf:resource="#DonXinHocTroLai"/>
  <coKetQua rdf:resource="#OutputDuocBaoLuu"/>
  <canCuQuyDinh rdf:resource="#RegQD1052"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quy trình xin bảo lưu kết quả học tập</rdfs:label>
  <noiDung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1. Sinh viên được xin nghỉ học tạm thời và bảo lưu kết quả đã học trong các trường hợp: Được điều động vào lực lượng vũ trang, đại diện quốc gia tham dự kỳ thi, bị ốm/thai sản/tai nạn hoặc vì lý do cá nhân khác.
2. Sinh viên xin nghỉ học tạm thời phải viết đơn xin thôi học gửi Hiệu trưởng thông qua Phòng Công tác sinh viên.
3. Khi muốn trở lại học tiếp, cần viết đơn gửi Hiệu trưởng thông qua Phòng Công tác sinh viên ít nhất 02 tuần trước khi bắt đầu học kỳ mới.</noiDung>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bao luu</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">điều kiện bảo lưu</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bảo lưu</tenGoiKhac>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#QuyTrinhChuyenNganh">
  <rdf:type rdf:resource="#QuyTrinhHocVu"/>
  <duocXuLyBoi rdf:resource="#PhongDaoTaoDaiHoc"/>
  <yeuCauDieuKien rdf:resource="#DieuKienChuyenNganhNamHoc"/>
