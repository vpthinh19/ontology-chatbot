  <coKetQua rdf:resource="#OutputNhanHocBong"/>
  <canCuQuyDinh rdf:resource="#RegQD1052"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quy trình xét học bổng</rdfs:label>
  <noiDung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trong học kì, sinh viên có kết quả học tập, rèn luyện từ loại khá trở lên, không bị kỉ luật từ mức khiển trách trở lên sẽ được xét cấp HBKK học tập.
Tổng số tín chỉ sinh viên đăng kí phải &gt;= 14. Học bổng sẽ được trao cho sinh viên theo thứ tự từ sinh viên có điểm học tập cao nhất lấy xuống đến khi đủ chỉ tiêu học bổng.</noiDung>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dkien xet hb</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dk hoc bong</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hoc bong</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">xet hb</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">xet hoc bong</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">học bổng</tenGoiKhac>
</owl:NamedIndividual>

