  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">xin chuyen nganh</tenGoiKhac>
  <tenGoiKhac rdf:datatype="http://www.w3.org/2001/XMLSchema#string">chuyen nganh</tenGoiKhac>
