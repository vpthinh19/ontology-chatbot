<owl:NamedIndividual rdf:about="#QuyTrinhXetHocBong">
  <rdf:type rdf:resource="#QuyTrinhHocVu"/>
  <duocXuLyBoi rdf:resource="#PhongCTSV"/>
  <yeuCauDieuKien rdf:resource="#DieuKienHocBongDiemRenLuyen"/>
