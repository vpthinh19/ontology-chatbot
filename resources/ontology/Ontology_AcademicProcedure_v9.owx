        <NamedIndividual IRI="#QuyetDinh1052"/>
        <Literal datatypeIRI="http://www.w3.org/2001/XMLSchema#anyURI">https://pdtdaihoc.ntu.edu.vn/uploads/38//245-Quyet%20dinh%201052%20(17-7-2025)%20ban%20hanh%20quy%20che%20dao%20tao%20trinh%20do%20dai%20hoc%20cua%20Truong%20DHNT.pdf</Literal>
    </DataPropertyAssertion>
