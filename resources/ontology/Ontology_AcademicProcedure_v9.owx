    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienBaoLuuCaNhan</IRI>
        <Literal>Vì lý do cá nhân khác nhưng phải học ít nhất 01 học kỳ ở Trường</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienBaoLuuQuocTe</IRI>
        <Literal>Được cơ quan có thẩm quyền điều động tham dự các kỳ thi, giải đấu quốc tế</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienBaoLuuVuTrang</IRI>
        <Literal>Được điều động vào lực lượng vũ trang</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienBaoLuuYTe</IRI>
        <Literal>Bị ốm, thai sản hoặc tai nạn phải điều trị thời gian dài có giấy chứng nhận hợp lệ</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienChuyenNganhNamHoc</IRI>
        <Literal>Không là sinh viên năm nhất hoặc năm cuối</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienHocBongDiemHocTap</IRI>
        <Literal>Kết quả học tập từ 7.0 trở lên</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DieuKienHocBongDiemRenLuyen</IRI>
        <Literal>Điểm rèn luyện từ loại khá trở lên</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
